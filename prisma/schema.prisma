// AutoFlow — Prisma Schema
// Database: PostgreSQL via Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  avatarUrl     String?
  role          Role     @default(USER)
  plan          Plan     @default(FREE)
  aiUsageCount  Int      @default(0)
  aiUsageLimit  Int      @default(100)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tasks          Task[]
  meetings       Meeting[]
  emails         EmailHistory[]
  calendarEvents CalendarEvent[]
  notifications  Notification[]
  workspaces     WorkspaceMember[]
  aiHistory      AiHistory[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}
enum Plan {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

model Task {
  id             String     @id @default(cuid())
  userId         String
  title          String
  description    String?
  priority       Priority   @default(MEDIUM)
  status         TaskStatus @default(PENDING)
  dueDate        DateTime?
  tags           String[]
  estimatedHours Float?
  completedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tasks")
  @@index([userId])
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}
enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Meeting {
  id              String   @id @default(cuid())
  userId          String
  title           String
  transcript      String   @db.Text
  summary         String?  @db.Text
  actionItems     Json?
  decisions       String[]
  keyTopics       String[]
  nextAgendaItems String[]
  sentiment       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("meetings")
  @@index([userId])
}

model EmailHistory {
  id        String   @id @default(cuid())
  userId    String
  original  String   @db.Text
  subject   String?
  replyBody String?  @db.Text
  tone      String   @default("professional")
  keyPoints String[]
  followup  String?
  sent      Boolean  @default(false)
  sentTo    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_history")
  @@index([userId])
}

model CalendarEvent {
  id              String   @id @default(cuid())
  userId          String
  title           String
  description     String?
  date            DateTime
  startTime       String
  endTime         String
  location        String?
  attendees       String[]
  reminderMinutes Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("calendar_events")
  @@index([userId])
  @@index([date])
}

model AiHistory {
  id        String   @id @default(cuid())
  userId    String
  agent     String
  input     String   @db.Text
  output    Json
  tokens    Int?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_history")
  @@index([userId])
  @@index([agent])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
  @@index([userId])
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  members   WorkspaceMember[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}
